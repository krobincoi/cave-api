# ════════════════════════════════════════════
# La Cave API — Variables d'environnement
# Copier en .env et remplir les valeurs
# ════════════════════════════════════════════

PORT=4000

# JWT — clé secrète (générez une chaîne aléatoire longue)
JWT_SECRET=changez-cette-cle-par-une-vraie-valeur-aleatoire-longue

# Resend — clé API (dashboard.resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email expéditeur (doit être un domaine vérifié dans Resend)
# Pour tester : utilisez onboarding@resend.dev (gratuit sans domaine)
EMAIL_FROM=La Cave <onboarding@resend.dev>

# URL de ce serveur (Railway vous donnera cette URL)
APP_URL=https://votre-api.railway.app

# Lien de téléchargement de l'app mobile
MOBILE_DOWNLOAD_URL=https://lacave.app/download
